<!DOCTYPE html>
<html>
<head>
    <title>Login User</title>
</head>
<body>

<h2>Login Form</h2>

<form action="logincheck" method="post">

    <label>Email:</label>
    <input type="email" name="email" required>
    <br><br>

    <label>Password:</label>
    <input type="password" name="password" required>
    <br><br>

    <button type="submit">Login</button>

</form>

</body>
</html>